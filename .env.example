# MediCore - Environment Variable Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env - it is gitignored.
# This file (.env.example) is safe to commit: it contains only placeholders.

# Supabase project URL (found in Supabase Dashboard -> Settings -> API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase publishable (anon) key - safe to use in frontend code
# NEVER use the service_role secret key here
VITE_SUPABASE_ANON_KEY=your_publishable_anon_key_here
